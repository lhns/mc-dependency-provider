{
  "schemaVersion": 1,
  "id": "fabric_example",
  "version": "${version}",
  "name": "mcdepprovider Fabric example",
  "description": "Smoke-test mod that exercises the mcdepprovider Scala entrypoint + Maven dep resolution path on Fabric.",
  "authors": ["mcdepprovider contributors"],
  "license": "Apache-2.0",

  "environment": "*",

  "mixins": [
    "fabric_example.mixins.json"
  ],

  "entrypoints": {
    "main": [
      {
        "adapter": "mcdepprovider",
        "value": "com.example.ExampleMod"
      }
    ]
  },

  "depends": {
    "fabricloader": ">=0.16.0",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "mcdepprovider": "*"
  }
}
