{
  "schemaVersion": 1,
  "id": "mcdepprovider",
  "version": "${version}",
  "name": "MC Dependency Provider",
  "description": "JVM-language mod provider with per-mod Maven dependency resolution for Fabric.",
  "authors": ["MC Dependency Provider contributors"],
  "contact": {
    "sources": "https://gitea.lhns.de/lhns/mc-dependency-provider"
  },
  "license": "Apache-2.0",

  "environment": "*",

  "languageAdapters": {
    "mcdepprovider": "de.lhns.mcdp.fabric.McdpLanguageAdapter"
  },

  "entrypoints": {
    "preLaunch": [
      "de.lhns.mcdp.fabric.McdpPreLaunch"
    ]
  },

  "depends": {
    "fabricloader": ">=0.16.0",
    "java": ">=21"
  }
}
