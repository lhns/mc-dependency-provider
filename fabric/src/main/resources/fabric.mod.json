{
  "schemaVersion": 1,
  "id": "mcdepprovider",
  "version": "${version}",
  "name": "mcdepprovider",
  "description": "JVM-language mod provider with per-mod Maven dependency resolution for Fabric.",
  "authors": ["mcdepprovider contributors"],
  "contact": {
    "sources": "https://gitea.lhns.de/lhns/mcdepprovider"
  },
  "license": "Apache-2.0",

  "environment": "*",

  "languageAdapters": {
    "mcdepprovider": "io.github.mcdepprovider.fabric.McLibLanguageAdapter"
  },

  "entrypoints": {
    "preLaunch": [
      "io.github.mcdepprovider.fabric.McLibPreLaunch"
    ]
  },

  "depends": {
    "fabricloader": ">=0.16.0",
    "java": ">=21"
  }
}
